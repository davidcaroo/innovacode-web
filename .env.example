# EmailJS — Envío de correos con SMTP personalizado (Hostinger)
# Crear cuenta en https://www.emailjs.com y conectar tu SMTP de Hostinger
# Dashboard: https://dashboard.emailjs.com

# ID del servicio creado en EmailJS (Email Services → tu servicio SMTP)
VITE_EMAILJS_SERVICE_ID=service_XXXXXXX

# ID de la plantilla de email (Email Templates → tu plantilla)
VITE_EMAILJS_TEMPLATE_ID=template_XXXXXXX

# Llave pública de tu cuenta EmailJS (Account → General)
VITE_EMAILJS_PUBLIC_KEY=XXXXXXXXXXXXXXX

# Si usas Supabase (opcional, no implementado actualmente)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
